# EchoMe configuration — copy to `.env` and fill in.
# `.env` is gitignored; never commit real keys. The LLM provider is pluggable:
# switch between local (free) and Claude (paid) by changing PROVIDER alone — no code change.

# Which LLM brain to use: "ollama" (free, local, dev) or "claude" (API, prod).
PROVIDER=ollama

# --- Ollama (free, local dev) ---
OLLAMA_MODEL=llama3.1
OLLAMA_URL=http://localhost:11434

# --- Claude (paid API, production) ---
# Get a key at https://console.anthropic.com/ — leave blank when using ollama.
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- Embeddings (local, used for RAG regardless of provider) ---
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Where the vector index is written (gitignored).
INDEX_DIR=index
