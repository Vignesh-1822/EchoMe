# EchoMe configuration — copy to `.env` and fill in.
# `.env` is gitignored; never commit real keys. The LLM provider is pluggable:
# switch providers by changing PROVIDER alone — no code change.

# Which LLM brain to use: "ollama" (free, local dev) | "openai" | "claude"
PROVIDER=openai

# --- Ollama (free, local dev) ---
OLLAMA_MODEL=llama3.1
OLLAMA_URL=http://localhost:11434

# --- OpenAI (paid API) ---
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_MODEL=gpt-4o-mini

# --- Claude (paid API, production) ---
# Get a key at https://console.anthropic.com/ — leave blank unless PROVIDER=claude.
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- Embeddings (local, used for RAG regardless of provider) ---
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Where the vector index is written (gitignored).
INDEX_DIR=index

# Retrieval relevance floor (cosine similarity, 0-1). Chunks below this are dropped;
# if nothing clears it, the twin says it doesn't know rather than guessing. Tune this.
MIN_SIMILARITY=0.25
